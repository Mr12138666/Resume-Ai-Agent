# Remote PGvector and MinIO via FRP tunnel.
# Copy this file to `.env` or load these variables in your shell before starting backend.
# Do not commit real passwords or access keys.

POSTGRES_URL=jdbc:postgresql://<remote-host>:<postgres-port>/robot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-server-password
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0

REDIS_HOST=<remote-host>
REDIS_PORT=<redis-port>
REDIS_PASSWORD=replace-with-redis-password
REDIS_TIMEOUT=1s
RESUME_AI_REDIS_ENABLED=true

MINIO_ENDPOINT=http://<remote-host>:<minio-api-port>
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=resume-ai

RESUME_AI_LLM_PROVIDER=ollama
SPRING_AI_CHAT_MODEL=ollama
SPRING_AI_EMBEDDING_MODEL=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
