POSTGRES_URL=jdbc:postgresql://localhost:5432/resume_ai
POSTGRES_USER=resume_ai
POSTGRES_PASSWORD=resume_ai
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=1s
RESUME_AI_REDIS_ENABLED=true

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resume-ai

# Remote server example:
# POSTGRES_URL=jdbc:postgresql://120.53.242.78:15432/robot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=replace-with-server-password
# MINIO_ENDPOINT=http://120.53.242.78:19000
# MINIO_ACCESS_KEY=replace-with-minio-access-key
# MINIO_SECRET_KEY=replace-with-minio-secret-key
# REDIS_HOST=120.53.242.78
# REDIS_PORT=16379
# REDIS_PASSWORD=replace-with-redis-password

RESUME_AI_LLM_PROVIDER=ollama
SPRING_AI_CHAT_MODEL=ollama
SPRING_AI_EMBEDDING_MODEL=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# For cloud/OpenAI-compatible models:
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
